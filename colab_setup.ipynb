    "\n",
    "print(f\"\"\"\\n🔍 SCRAPER CONFIGURATION\n",
    "━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "Location:    {full_location}\n",
    "Business:    {BUSINESS_TYPE}\n",
    "Output:      {output_file}\n",
    "Headless:    {HEADLESS_MODE}\n",
    "━━━━━━━━━━━━━━━━━━━━━━━━━━━━\\n\"\"\")\n",
    "\n",
    "print(\"Starting scraper...\\n\")\n",
    "\n",
    "try:\n",
    "    pipeline = ScrapingPipeline(headless=HEADLESS_MODE)\n",
    "    results = pipeline.run(\n",
    "        location=full_location,\n",
    "        business_type=BUSINESS_TYPE,\n",
    "        output_file=output_file,\n",
    "        place_type=selected_location.place_type,\n",
    "    )\n",
    "    \n",
    "    if results:\n",
    "        print(f\"\\n✓ Scraping complete! Found {len(results)} results.\")\n",
    "    else:\n",
    "        print(\"\\n⚠️  No results found. Google may be blocking requests or no listings exist.\")\n",
    "        \nexcept Exception as e:\n",
    "    print(f\"\\n❌ Error during scraping: {e}\")\n",
    "    import traceback\n",
    "    traceback.print_exc()"
   ]
